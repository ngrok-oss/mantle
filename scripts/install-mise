#!/usr/bin/env bash
# Install and activate the pinned mise binary used by this repository.

set -euo pipefail

MISE_VERSION="${MISE_VERSION:-v2026.4.28}"
MISE_EXPECTED_VERSION="${MISE_VERSION#v}"

sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    shasum -a 256 "$1" | awk '{print $1}'
  fi
}

detect_mise_platform() {
  local os arch

  os="$(uname -s)"
  arch="$(uname -m)"

  case "${os}" in
    Linux) os="linux" ;;
    Darwin) os="macos" ;;
    *)
      echo "mantle: unsupported OS for automatic mise install: ${os}" >&2
      return 1
      ;;
  esac

  case "${arch}" in
    x86_64|amd64) arch="x64" ;;
    arm64|aarch64) arch="arm64" ;;
    *)
      echo "mantle: unsupported architecture for automatic mise install: ${arch}" >&2
      return 1
      ;;
  esac

  printf '%s-%s' "${os}" "${arch}"
}

install_pinned_mise() {
  local mise_platform mise_asset mise_base_url tmpdir expected_sha256 actual_sha256

  mise_platform="$(detect_mise_platform)"
  mise_asset="mise-${MISE_VERSION}-${mise_platform}"
  mise_base_url="https://github.com/jdx/mise/releases/download/${MISE_VERSION}"
  tmpdir="$(mktemp -d)"

  cleanup() {
    rm -rf "${tmpdir}"
  }
  trap cleanup EXIT

  curl -fsSL "${mise_base_url}/${mise_asset}" -o "${tmpdir}/mise"
  curl -fsSL "${mise_base_url}/SHASUMS256.txt" -o "${tmpdir}/SHASUMS256.txt"

  expected_sha256="$(awk -v asset="./${mise_asset}" '$2 == asset {print $1}' "${tmpdir}/SHASUMS256.txt")"
  if [ -z "${expected_sha256}" ]; then
    echo "mantle: checksum not found for mise release asset ${mise_asset}" >&2
    exit 1
  fi

  actual_sha256="$(sha256_file "${tmpdir}/mise")"
  if [ "${actual_sha256}" != "${expected_sha256}" ]; then
    echo "mantle: checksum verification failed for mise ${MISE_VERSION}" >&2
    exit 1
  fi

  mkdir -p "${HOME}/.local/bin"
  install -m 0755 "${tmpdir}/mise" "${HOME}/.local/bin/mise"
  cleanup
  trap - EXIT
}

ensure_pinned_mise() {
  local installed_mise_version active_mise_version

  if ! command -v mise >/dev/null 2>&1; then
    echo "mantle: installing mise ${MISE_VERSION}..."
    install_pinned_mise
    export PATH="${HOME}/.local/bin:${PATH}"
  else
    installed_mise_version="$(mise --version | awk '{print $1}')"
    if [ "${installed_mise_version}" != "${MISE_EXPECTED_VERSION}" ]; then
      echo "mantle: found mise ${installed_mise_version}, installing ${MISE_VERSION}..."
      install_pinned_mise
      export PATH="${HOME}/.local/bin:${PATH}"
    fi
  fi

  active_mise_version="$(mise --version | awk '{print $1}')"
  if [ "${active_mise_version}" != "${MISE_EXPECTED_VERSION}" ]; then
    echo "mantle: mise ${MISE_EXPECTED_VERSION} is required, but $(mise --version) is active" >&2
    echo "        ensure ${HOME}/.local/bin appears before other mise installs on PATH." >&2
    exit 1
  fi

  if [ -x "${HOME}/.local/bin/mise" ] && [ "$("${HOME}/.local/bin/mise" --version | awk '{print $1}')" = "${MISE_EXPECTED_VERSION}" ]; then
    export PATH="${HOME}/.local/bin:${PATH}"
  fi
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  ensure_pinned_mise
fi
