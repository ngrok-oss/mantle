{
  "name": "@ngrok/mantle-vite-plugins",
  "version": "0.1.5",
  "description": "Vite plugins for @ngrok/mantle.",
  "homepage": "https://mantle.ngrok.com",
  "license": "MIT",
  "author": "ngrok",
  "repository": {
    "type": "git",
    "url": "https://github.com/ngrok-oss/mantle"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "@ngrok/src-live-types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./server-highlighter": {
      "types": "./dist/server-highlighter.d.ts",
      "@ngrok/src-live-types": "./src/server-highlighter/index.ts",
      "import": "./dist/server-highlighter.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsx scripts/generate-component-names.ts && tsdown",
    "generate": "tsx scripts/generate-component-names.ts",
    "test": "TZ=UTC vitest run",
    "test:watch": "TZ=UTC vitest watch",
    "typecheck": "tsx scripts/generate-component-names.ts && tsgo"
  },
  "dependencies": {
    "magic-string": "0.30.21",
    "oxc-parser": "0.86.0",
    "shiki": "4.0.1"
  },
  "devDependencies": {
    "@cfg/tsconfig": "workspace:*",
    "@ngrok/mantle": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@ngrok/mantle": "*",
    "vite": "^6 || ^7"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": "^24.0.0"
  }
}
