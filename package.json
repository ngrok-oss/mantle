{
  "name": "mantle",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start",
    "serve": "turbo run serve",
    "clean": "turbo run clean",
    "clean:node_modules": "node ./scripts/clean-node-modules.js",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt --write",
    "lint:fix": "oxlint --fix",
    "lint": "oxlint",
    "install:playwright": "node ./scripts/install-playwright.js",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "turbo run build --filter=@ngrok/mantle --filter=@ngrok/mantle-vite-plugins --filter=@ngrok/mantle-server-syntax-highlighter && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260612.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.56.0",
    "oxlint": "1.70.0",
    "tsx": "catalog:",
    "turbo": "2.10.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
