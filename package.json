{
  "name": "mantle",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start",
    "serve": "turbo run serve",
    "clean": "turbo run clean",
    "clean:node_modules": "node ./scripts/clean-node-modules.js",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt --write",
    "lint:fix": "oxlint --fix",
    "lint": "oxlint",
    "install:playwright": "node ./scripts/install-playwright.js",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "turbo run build --filter=@ngrok/mantle --filter=@ngrok/mantle-vite-plugins --filter=@ngrok/mantle-server-syntax-highlighter && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "tsx": "catalog:",
    "turbo": "2.9.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@types/node": "catalog:",
      "@mjackson/node-fetch-server": "npm:@remix-run/node-fetch-server@0.10.0",
      "@vitejs/plugin-react": "catalog:",
      "ajv": ">=8.18.0",
      "cookie": ">=1.1.1",
      "esbuild": ">=0.27.5",
      "playwright-core": "catalog:",
      "react": "19.2.4",
      "react-dom": "19.2.4"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ]
  }
}
